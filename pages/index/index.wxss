.page-index{padding-bottom:20px;background:#F5F0E8}
.banner-swiper{height:160px}
.banner-slide{height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;text-shadow:0 2px 4px rgba(0,0,0,.3)}
.banner-emoji{font-size:40px;margin-bottom:4px}
.banner-title{font-size:18px;font-weight:700}
.banner-sub{font-size:12px;opacity:.9;margin-top:4px}
.marquee-bar{background:#1a1a2e;color:#FFD700;padding:8px 16px;margin:0 12px;border-radius:6px;overflow:hidden;font-size:11px}
.marquee-inner{white-space:nowrap;animation:marquee 20s linear infinite}
@keyframes marquee{0%{transform:translateX(100%)}100%{transform:translateX(-100%)}}
.cate-grid{display:flex;background:#fff;padding:12px 8px;margin:10px 12px;border-radius:8px}
.cate-item{flex:1;text-align:center;padding:4px}
.cate-emoji{font-size:28px;display:block;margin-bottom:4px}
.cate-name{font-size:11px;color:#3D3226}
.event-card{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;margin:10px 12px;background:linear-gradient(135deg,#8B5E3C,#5C3A1E);color:#fff;border-radius:10px}
.event-left{flex:1}
.event-title{font-size:16px;font-weight:700;display:block}
.event-sub{font-size:11px;opacity:.85;display:block;margin-top:2px}
.btn-gold{background:linear-gradient(135deg,#C8963E,#A67B2E);padding:8px 18px;border-radius:20px;font-size:12px;font-weight:600}
.section-title{padding:14px 16px 8px;font-size:15px;font-weight:700}
.activity-grid{display:flex;padding:0 12px;gap:8px}
.act-card{flex:1;background:#fff;border-radius:10px;padding:12px 6px;text-align:center}
.act-emoji{font-size:26px;display:block}
.act-name{font-size:11px;font-weight:600;display:block;margin-top:4px}
.act-desc{font-size:9px;color:#999;display:block}
.product-list{padding:0 12px}
.product-card{display:flex;background:#fff;border-radius:10px;margin-bottom:10px;overflow:hidden}
.product-img-wrap{width:100px;height:100px;display:flex;align-items:center;justify-content:center}
.product-emoji{font-size:36px}
.product-info{flex:1;padding:10px;display:flex;flex-direction:column;justify-content:space-between}
.product-name{font-size:13px;font-weight:700}
.product-desc{font-size:11px;color:#999}
.product-bottom{display:flex;justify-content:space-between;align-items:center}
.price{color:#C8963E;font-weight:800;font-size:15px}
.price-original{color:#999;text-decoration:line-through;font-size:11px;margin-left:4px}
.tag{font-size:10px;padding:2px 6px;border-radius:4px;color:#fff}
.tag-hot{background:#FF4757}
.tag-new{background:#5C8A45}
.partner-bar{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;margin:10px 12px;background:linear-gradient(135deg,#8B5E3C,#5C3A1E);color:#fff;border-radius:10px}
.partner-title{font-size:14px;font-weight:700;display:block}
.partner-desc{font-size:11px;opacity:.85;display:block;margin-top:2px}
.btn-outline{border:1px solid #fff;padding:6px 14px;border-radius:16px;font-size:12px}

.product-img { width: 100%; height: 100%; }
