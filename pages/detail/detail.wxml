<view class="page-detail">
  <image class="hero-img" src="{{product.image||'/images/product-80g.jpg'}}" mode="aspectFill"></image>
  <view class="info-section">
    <text class="product-name">{{product.name}}</text>
    <text class="product-desc">{{product.desc}}</text>
    <view class="price-row">
      <text class="price-now">{{product.price}}元</text>
      <text class="price-old" wx:if="{{product.marketPrice}}">{{product.marketPrice}}元</text>
    </view>
  </view>
  <view class="action-bar">
    <button class="btn-primary" bindtap="onShare">推荐给朋友</button>
    <button class="btn-gold" bindtap="onShowOrder">立即购买</button>
  </view>

  <!-- Order Modal -->
  <view class="order-overlay" wx:if="{{showOrder}}" catchtap="onHideOrder">
    <view class="order-modal" catchtap="">
      <text class="order-title">确认订单</text>
      <view class="order-product">
        <text>{{product.name}} x {{orderQuantity}}</text>
        <text>{{orderTotal}}元</text>
      </view>
      <view class="order-qty">
        <text class="qty-btn" bindtap="onQtyChange" data-type="minus">-</text>
        <text class="qty-num">{{orderQuantity}}</text>
        <text class="qty-btn" bindtap="onQtyChange" data-type="plus">+</text>
      </view>
      <input class="order-input" placeholder="您的姓名" value="{{orderName}}" bindinput="onNameInput"/>
      <input class="order-input" placeholder="联系电话" value="{{orderPhone}}" bindinput="onPhoneInput" type="number"/>
      <button class="btn-submit" bindtap="onSubmit">提交订单</button>
    </view>
  </view>
</view>