.page { padding-bottom: 120rpx; }
.section { padding: 30rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; padding: 20rpx 30rpx; background: #fff; box-shadow: 0 -2rpx 16rpx rgba(0,0,0,.06); }
.order-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);display:flex;align-items:flex-end;z-index:100}
.order-modal{background:#fff;width:100%;border-radius:20px 20px 0 0;padding:25px 20px 40px}
.order-title{font-size:18px;font-weight:bold;text-align:center;display:block;margin-bottom:20px}
.order-product{display:flex;justify-content:space-between;padding:10px 0;font-size:15px;border-bottom:1px solid #f0f0f0}
.order-qty{display:flex;align-items:center;justify-content:center;gap:20px;margin:15px 0}
.qty-btn{width:36px;height:36px;border-radius:50%;background:#f5f5f5;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:bold}
.qty-num{font-size:20px;font-weight:bold}
.order-input{width:100%;padding:12px;border:1px solid #e0e0e0;border-radius:10px;font-size:14px;margin-bottom:12px;box-sizing:border-box}
.btn-submit{background:linear-gradient(135deg,#8B5E3C,#C8963E);color:#fff;border-radius:25px;font-size:16px;font-weight:bold;margin-top:10px}
.btn-primary{flex:1;background:#f5f5f5;color:#333;border-radius:25px;margin-right:8px}
.btn-gold{flex:2;background:linear-gradient(135deg,#8B5E3C,#C8963E);color:#fff;border-radius:25px}
