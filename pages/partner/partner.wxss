.page-partner{background:#F5F0E8;padding-bottom:30px}

.partner-hero{background:linear-gradient(135deg,#5C3A1E,#8B5E3C);color:#fff;padding:30px 16px;text-align:center}
.ph-title{font-size:22px;font-weight:800;display:block}
.ph-sub{font-size:13px;opacity:.9;display:block;margin-top:8px}
.ph-desc{font-size:11px;opacity:.7;display:block;margin-top:6px}

.card{background:#fff;margin:10px 12px;border-radius:12px;padding:14px}
.card-title{font-size:15px;font-weight:700;margin-bottom:10px}

.tier-scroll{display:flex;gap:8px}
.tier-card{flex:1;background:#FAF8F4;border-radius:12px;padding:12px 8px;text-align:center;border:2px solid #eee;position:relative;min-width:0}
.tier-card.recommended{border-color:#C8963E;background:#FFF9E6}
.tier-badge{position:absolute;top:-8px;left:50%;transform:translateX(-50%);background:#C8963E;color:#fff;font-size:9px;padding:2px 8px;border-radius:10px}
.tier-icon{font-size:24px;display:block}
.tier-name{font-weight:700;font-size:12px;display:block;margin:4px 0}
.tier-target{font-size:10px;color:#666;display:block}
.tier-comm{font-weight:800;font-size:16px;display:block;margin:6px 0}
.tier-benefits{text-align:left;font-size:8px;line-height:1.6}
.tb-item{display:block;color:#666}

.adv-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.adv-item{background:#FAF8F4;border-radius:8px;padding:10px;text-align:center}
.adv-emoji{font-size:22px;display:block}
.adv-title{font-weight:600;font-size:13px;display:block;margin:4px 0}
.adv-desc{font-size:10px;color:#999;display:block}

.faq-item{background:#FAF8F4;border-radius:8px;padding:10px;margin-bottom:6px}
.faq-q{font-weight:600;font-size:12px;display:block}
.faq-a{font-size:11px;color:#666;display:block;margin-top:4px;line-height:1.5}

.partner-cta{background:linear-gradient(135deg,#C8963E,#A67B2E);margin:14px 12px;padding:14px;border-radius:12px;text-align:center;box-shadow:0 4px 12px rgba(200,150,62,.3)}
.cta-btn{color:#fff;font-size:16px;font-weight:700}

.form-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:center;justify-content:center}
.form-modal{background:#fff;width:300px;border-radius:16px;padding:20px}
.form-title{font-size:16px;font-weight:700;text-align:center;display:block;margin-bottom:16px}
.form-input{background:#F5F0E8;border-radius:8px;padding:10px;margin-bottom:8px;font-size:13px}
.form-btns{display:flex;gap:10px;margin-top:14px}
.form-cancel{flex:1;background:#eee;border:none;padding:10px;border-radius:8px;font-size:13px}
.form-submit{flex:1;background:linear-gradient(135deg,#8B5E3C,#5C3A1E);color:#fff;border:none;padding:10px;border-radius:8px;font-size:13px}