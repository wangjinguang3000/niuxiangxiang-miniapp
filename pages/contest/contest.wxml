<view class="page">
  <view class="header">
    <view class="header-bg"></view>
    <text class="header-title">人宠互动季 S1</text>
    <text class="header-sub">草原上的毛孩子狂欢</text>
  </view>

  <view class="contest-card">
    <view class="contest-status">
      <text class="phase-badge">火热报名中</text>
      <text class="countdown" wx:if="{{countdown}}">剩余 {{countdown}}</text>
    </view>
    <text class="contest-name">草原人宠互动季 S1</text>
    <text class="contest-theme">锡林郭勒·多伦草原·3天2晚</text>
    <view class="contest-detail">
      <text>Day1 周五：多伦集合接驳 → 蒙古包入住 → 烤全羊欢迎晚宴</text>
      <text>Day2 周六：意志力挑战 → 叼物接力 → 障碍赛 → 才艺秀 → 颁奖</text>
      <text>Day3 周日：草原自由活动 → 代言狗评选 → 闭幕预告</text>
    </view>
  </view>

  <view class="section-title">参赛套餐</view>
  <view class="package-list">
    <view class="pkg-card">
      <text class="pkg-name">早鸟参赛（限前20组）</text>
      <text class="pkg-price">1,780元</text>
      <text class="pkg-desc">1人+1狗·3天2晚全包·冠军奖金8,000元</text>
    </view>
    <view class="pkg-card">
      <text class="pkg-name">标准参赛</text>
      <text class="pkg-price">1,980元</text>
      <text class="pkg-desc">1人+1狗·3天2晚全包·赠品价值超539元</text>
    </view>
    <view class="pkg-card">
      <text class="pkg-name">观摩票</text>
      <text class="pkg-price">1,280元</text>
      <text class="pkg-desc">不参赛·3天2晚住宿餐饮全包·欢迎带狗围观</text>
    </view>
  </view>

  <view class="section-title">奖项说明</view>
  <view class="prize-grid">
    <view class="prize-item gold">
      <text class="prize-emoji">冠军</text>
      <text class="prize-desc">5000金币</text>
      <text class="prize-desc">牛肝干480g礼盒x2</text>
    </view>
    <view class="prize-item silver">
      <text class="prize-emoji">亚军</text>
      <text class="prize-desc">3000金币</text>
      <text class="prize-desc">牛肝干240gx2</text>
    </view>
    <view class="prize-item bronze">
      <text class="prize-emoji">季军</text>
      <text class="prize-desc">1500金币</text>
      <text class="prize-desc">牛肝干80gx3</text>
    </view>
  </view>
</view>