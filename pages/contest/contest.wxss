.page { background:#F5F0E8; min-height:100vh; padding-bottom:40rpx; }

/* 顶部 */
.header { padding:60rpx 30rpx 40rpx; background:linear-gradient(135deg,#FF6B35,#F7931E); color:#fff; text-align:center; }
.header-title { font-size:40rpx; font-weight:800; display:block; }
.header-sub { font-size:24rpx; opacity:.8; display:block; margin-top:8rpx; }

/* 当前赛事卡 */
.contest-card { background:#fff; margin:24rpx; border-radius:20rpx; padding:30rpx; box-shadow:0 4rpx 20rpx rgba(0,0,0,.06); }
.contest-status { display:flex; justify-content:space-between; align-items:center; margin-bottom:16rpx; }
.phase-badge { background:#FF6B35; color:#fff; padding:6rpx 20rpx; border-radius:20rpx; font-size:24rpx; font-weight:600; }
.countdown { color:#FF6B35; font-size:24rpx; font-weight:600; }
.contest-name { font-size:34rpx; font-weight:800; color:#333; display:block; margin-bottom:8rpx; }
.contest-theme { font-size:26rpx; color:#666; display:block; margin-bottom:16rpx; }
.contest-stats { display:flex; gap:30rpx; margin-bottom:12rpx; }
.contest-stats text { font-size:24rpx; color:#999; }
.contest-vote-info { background:#FFF9E6; border-radius:12rpx; padding:12rpx 20rpx; margin-bottom:20rpx; }
.contest-vote-info text { font-size:22rpx; color:#C8963E; }
.contest-actions { display:flex; gap:20rpx; }
.contest-actions .btn { flex:1; text-align:center; padding:20rpx; border-radius:16rpx; font-size:28rpx; font-weight:700; }
.btn-primary { background:#8B5E3C; color:#fff; }
.btn-gold { background:linear-gradient(135deg,#FFD700,#F7931E); color:#fff; }

/* 赛事列表 */
.section-title { font-size:30rpx; font-weight:800; color:#333; padding:30rpx 30rpx 16rpx; }
.contest-list { padding:0 24rpx; }
.contest-list-item { background:#fff; border-radius:16rpx; padding:24rpx; margin-bottom:16rpx; display:flex; align-items:center; justify-content:space-between; box-shadow:0 2rpx 12rpx rgba(0,0,0,.04); }
.cli-left { flex:1; }
.cli-phase { font-size:22rpx; color:#8B5E3C; display:block; }
.cli-title { font-size:28rpx; font-weight:700; color:#333; display:block; margin-top:4rpx; }
.cli-theme { font-size:22rpx; color:#999; display:block; margin-top:4rpx; }
.cli-arrow { font-size:36rpx; color:#ccc; }

/* 奖励网格 */
.prize-grid { display:flex; gap:16rpx; padding:0 24rpx; }
.prize-item { flex:1; background:#fff; border-radius:16rpx; padding:24rpx 16rpx; text-align:center; box-shadow:0 2rpx 12rpx rgba(0,0,0,.04); }
.prize-item.gold { border-top:4rpx solid #FFD700; }
.prize-item.silver { border-top:4rpx solid #C0C0C0; }
.prize-item.bronze { border-top:4rpx solid #CD7F32; }
.prize-emoji { font-size:48rpx; display:block; }
.prize-name { font-size:28rpx; font-weight:700; color:#333; display:block; margin-top:8rpx; }
.prize-desc { font-size:20rpx; color:#999; display:block; margin-top:4rpx; }

/* 排行榜弹窗 */
.detail-modal { position:fixed; top:0; left:0; right:0; bottom:0; z-index:100; visibility:hidden; }
.detail-modal.show { visibility:visible; }
.detail-overlay { position:absolute; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,.5); }
.detail-panel { position:absolute; bottom:0; left:0; right:0; background:#fff; border-radius:24rpx 24rpx 0 0; height:75vh; display:flex; flex-direction:column; }
.detail-header { display:flex; justify-content:space-between; align-items:center; padding:24rpx 30rpx; border-bottom:1rpx solid #eee; }
.detail-title { font-size:30rpx; font-weight:800; color:#333; }
.detail-close { font-size:36rpx; color:#999; padding:10rpx; }
.detail-vote-hint { padding:12rpx 30rpx; background:#FFF9E6; }
.detail-vote-hint text { font-size:22rpx; color:#C8963E; }
.detail-list { flex:1; padding:16rpx; }
.rank-item { display:flex; align-items:center; padding:20rpx 12rpx; border-bottom:1rpx solid #f5f5f5; }
.rank-num { width:60rpx; text-align:center; font-size:32rpx; font-weight:800; color:#999; }
.rank-num.top3 { font-size:40rpx; }
.rank-avatar { width:60rpx; height:60rpx; border-radius:50%; background:#C8963E; color:#fff; font-size:24rpx; display:flex; align-items:center; justify-content:center; margin:0 16rpx; flex-shrink:0; }
.rank-info { flex:1; }
.rank-name { font-size:26rpx; font-weight:600; color:#333; display:block; }
.rank-title { font-size:22rpx; color:#999; display:block; margin-top:2rpx; }
.rank-votes { text-align:right; }
.rank-count { font-size:24rpx; color:#FF6B35; font-weight:600; display:block; }
.btn-vote { display:inline-block; margin-top:8rpx; padding:8rpx 24rpx; border-radius:20rpx; background:#FF6B35; color:#fff; font-size:22rpx; font-weight:600; }
.btn-vote.voted { background:#ccc; }
.entry-empty { text-align:center; color:#999; padding:80rpx 0; font-size:26rpx; }
