.page-admin{background:#F5F0E8;padding-bottom:20px}
.hero{background:linear-gradient(135deg,#1a1a2e,#0f3460);color:#fff;padding:30px 16px;text-align:center}
.hero-title{font-size:20px;font-weight:700;display:block}
.hero-sub{font-size:12px;opacity:.85;display:block;margin-top:4px}
.stats-row{display:flex;padding:10px 12px;gap:8px}
.stat-card{flex:1;background:#fff;border-radius:10px;padding:16px;text-align:center}
.stat-val{font-size:24px;font-weight:800;color:#C8963E;display:block}
.stat-label{font-size:11px;color:#999;display:block;margin-top:4px}
.section-title{padding:14px 16px 8px;font-size:15px;font-weight:700}
.menu-list{background:#fff;margin:0 12px;border-radius:10px;overflow:hidden}
.menu-item{display:flex;align-items:center;padding:14px;border-bottom:1px solid #f0f0f0}
.mi{font-size:22px;margin-right:12px}
.mt{flex:1;font-size:13px}
.ma{font-size:18px;color:#ccc}
.order-card{background:#fff;margin:8px 12px;border-radius:10px;padding:14px}
.oh{display:flex;justify-content:space-between;font-size:11px;color:#999;margin-bottom:8px}
.of{text-align:right;font-size:13px;font-weight:700;color:#C8963E;margin-top:6px}
