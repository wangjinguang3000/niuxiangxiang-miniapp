<view class="page-admin">
  <view class="hero">
    <text class="hero-title">管理后台</text>
    <text class="hero-sub">商品管理 | 订单查看 | 数据统计 | 功能开关</text>
  </view>

  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-val">{{stats.userCount || 0}}</text>
      <text class="stat-label">用户数</text>
    </view>
    <view class="stat-card">
      <text class="stat-val">{{stats.orderCount || 0}}</text>
      <text class="stat-label">订单数</text>
    </view>
    <view class="stat-card">
      <text class="stat-val">{{stats.productCount || 0}}</text>
      <text class="stat-label">商品数</text>
    </view>
  </view>

  <!-- 功能开关区 -->
  <view class="section-title">功能开关</view>
  <view class="toggle-card">
    <view class="toggle-row">
      <view class="toggle-info">
        <text class="toggle-label">互动板块功能</text>
        <text class="toggle-desc">开启后互动板块跳转完整版</text>
      </view>
      <switch checked="{{ugcEnabled}}" bindchange="onToggleUGC" color="#8B5E3C"/>
    </view>
    <view class="toggle-status" style="color:{{ugcEnabled?'#4CAF50':'#FF9800'}}">
      当前状态：{{ugcEnabled ? '完整模式' : '审核模式'}}
    </view>
  </view>

  <view class="toggle-card">
    <view class="toggle-row">
      <view class="toggle-info">
        <text class="toggle-label">审核安全模式</text>
        <text class="toggle-desc">提交审核前务必开启此模式</text>
      </view>
      <switch checked="{{reviewMode}}" bindchange="onToggleReview" color="#8B5E3C"/>
    </view>
    <view class="toggle-status" style="color:{{reviewMode?'#4CAF50':'#FF9800'}}">
      {{reviewMode ? '审核安全模式 - 提交审核用' : '正常运行模式'}}
    </view>
  </view>

  <view class="section-title">功能操作</view>
  <view class="menu-list">
    <view class="menu-item" bindtap="initDB">
      <text class="mi">📦</text>
      <text class="mt">初始化商品数据</text>
      <text class="ma">></text>
    </view>
    <view class="menu-item" bindtap="refreshStats">
      <text class="mi">🔄</text>
      <text class="mt">刷新统计</text>
      <text class="ma">></text>
    </view>
  </view>

  <view class="section-title">最近订单</view>
  <view wx:if="{{stats.recentOrders && stats.recentOrders.length > 0}}">
    <view class="order-card" wx:for="{{stats.recentOrders}}" wx:key="orderId">
      <view class="oh">
        <text>{{item.orderId}}</text>
        <text>{{item.status}}</text>
      </view>
      <view wx:for="{{item.items}}" wx:key="name" wx:for-item="it">
        <text>{{it.name}} x {{it.price}}</text>
      </view>
      <view class="of">实付: {{item.total}}</view>
    </view>
  </view>
  <view wx:else style="text-align:center;padding:20px;color:#999">
    <text>暂无订单</text>
  </view>
</view>