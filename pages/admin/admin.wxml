<view class="page-admin">
  <view class="hero">
    <text class="hero-title">管理后台</text>
    <text class="hero-sub">商品管理 | 订单查看 | 数据统计</text>
  </view>

  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-val">{{stats.userCount || 0}}</text>
      <text class="stat-label">用户数</text>
    </view>
    <view class="stat-card">
      <text class="stat-val">{{stats.orderCount || 0}}</text>
      <text class="stat-label">订单数</text>
    </view>
    <view class="stat-card">
      <text class="stat-val">{{stats.productCount || 0}}</text>
      <text class="stat-label">商品数</text>
    </view>
  </view>

  <view class="section-title">功能操作</view>
  <view class="menu-list">
    <view class="menu-item" bindtap="initDB">
      <text class="mi">\u{1F4E6}</text>
      <text class="mt">初始化商品数据</text>
      <text class="ma">></text>
    </view>
    <view class="menu-item" bindtap="refreshStats">
      <text class="mi">\u{1F504}</text>
      <text class="mt">刷新统计</text>
      <text class="ma">></text>
    </view>
  </view>

  <view class="section-title">最近订单</view>
  <view wx:if="{{stats.recentOrders && stats.recentOrders.length > 0}}">
    <view class="order-card" wx:for="{{stats.recentOrders}}" wx:key="orderId">
      <view class="oh">
        <text>{{item.orderId}}</text>
        <text>{{item.status}}</text>
      </view>
      <view wx:for="{{item.items}}" wx:key="name" wx:for-item="it">
        <text>{{it.name}} x {{it.price}}</text>
      </view>
      <view class="of">实付: {{item.total}}</view>
    </view>
  </view>
  <view wx:else style="text-align:center;padding:20px;color:#999">
    <text>暂无订单</text>
  </view>
</view>