.dash-page{background:#F5F0E8;min-height:100vh;padding:20px}
.dash-hero{text-align:center;padding:30px 0}
.dash-name{font-size:24px;font-weight:bold;color:#333;display:block}
.dash-plan{font-size:13px;color:#8B5E3C;margin-top:8px;display:block}
.stat-row{display:flex;background:#fff;border-radius:12px;padding:15px;margin-bottom:20px}
.stat-item{flex:1;text-align:center}
.si-val{font-size:22px;font-weight:bold;color:#8B5E3C;display:block}
.si-label{font-size:11px;color:#999;margin-top:4px;display:block}
.menu-list{background:#fff;border-radius:12px;overflow:hidden}
.menu-item{display:flex;justify-content:space-between;padding:16px 18px;border-bottom:1px solid #f5f5f5;font-size:15px}
.menu-item:last-child{border-bottom:none}
