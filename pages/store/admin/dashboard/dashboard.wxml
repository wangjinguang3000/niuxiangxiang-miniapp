<view class="dash-page">
  <view class="dash-hero">
    <text class="dash-name">{{store.name||'我的门店'}}</text>
    <text class="dash-plan">{{store.plan==='premium'?'高级会员':'免费会员'}}</text>
  </view>
  <view class="stat-row">
    <view class="stat-item"><text class="si-val">{{stats.productCount}}</text><text class="si-label">产品数</text></view>
    <view class="stat-item"><text class="si-val">{{stats.orderCount}}</text><text class="si-label">总订单</text></view>
    <view class="stat-item"><text class="si-val">{{stats.todayOrders}}</text><text class="si-label">今日订单</text></view>
    <view class="stat-item"><text class="si-val">¥{{stats.todayAmount}}</text><text class="si-label">今日收入</text></view>
  </view>
  <view class="menu-list">
    <view class="menu-item" bindtap="goProducts"><text>📦 产品管理</text><text>></text></view>
    <view class="menu-item" bindtap="goOrders"><text>📋 订单管理</text><text>></text></view>
    <view class="menu-item" bindtap="goSettings"><text>⚙️ 店铺设置</text><text>></text></view>
    <view class="menu-item" bindtap="goPreview"><text>👀 预览门店</text><text>></text></view>
  </view>
</view>
