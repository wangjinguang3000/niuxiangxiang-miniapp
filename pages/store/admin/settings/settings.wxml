<view class="set-page">
  <view class="form-group"><text class="fg-label">门店名称</text><input class="fg-input" value="{{store.name}}" bindinput="onInput" data-field="name" placeholder="输入门店名称"/></view>
  <view class="form-group"><text class="fg-label">简介</text><input class="fg-input" value="{{store.intro}}" bindinput="onInput" data-field="intro" placeholder="一句话介绍"/></view>
  <view class="form-group"><text class="fg-label">电话</text><input class="fg-input" value="{{store.phone}}" bindinput="onInput" data-field="phone" placeholder="联系电话"/></view>
  <view class="form-group"><text class="fg-label">地址</text><input class="fg-input" value="{{store.address}}" bindinput="onInput" data-field="address" placeholder="门店地址"/></view>
  <view class="form-group"><text class="fg-label">营业时间</text><input class="fg-input" value="{{store.hours}}" bindinput="onInput" data-field="hours" placeholder="09:00-21:00"/></view>
  <button class="save-btn" bindtap="onSave">保存设置</button>
</view>
