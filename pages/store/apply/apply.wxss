.apply-page{padding:15px;background:#F5F0E8;min-height:100vh}
.apply-hero{text-align:center;padding:30px 0}
.ah-title{font-size:24px;font-weight:bold;color:#333;display:block;margin-bottom:8px}
.ah-desc{font-size:14px;color:#999;display:block;margin-bottom:20px}
.ah-benefits{text-align:left;background:#fff;border-radius:12px;padding:20px}
.ahb-item{display:block;font-size:14px;color:#333;padding:6px 0}
.form-group{margin-bottom:18px}
.fg-label{font-size:14px;font-weight:bold;color:#333;margin-bottom:6px;display:block}
.fg-input{width:100%;padding:12px;border:1px solid #e0e0e0;border-radius:10px;font-size:14px;background:#fff;box-sizing:border-box}
.submit-btn{background:linear-gradient(135deg,#8B5E3C,#C8963E);color:#fff;border-radius:25px;margin-top:20px;font-size:16px;font-weight:bold}
