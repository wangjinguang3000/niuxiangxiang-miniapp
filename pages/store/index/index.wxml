<view class="store-page" wx:if="{{!loading}}">
  <!-- Hero -->
  <view class="store-hero" style="background:linear-gradient(135deg,{{store.color||'#8B5E3C'}},{{store.color||'#8B5E3C'}}dd)">
    <image class="store-logo" src="{{store.logo}}" mode="aspectFit" wx:if="{{store.logo}}"></image>
    <text class="store-name" wx:if="{{!store.logo}}">{{store.name}}</text>
    <text class="store-intro">{{store.intro||'欢迎光临'}}</text>
    <view class="store-actions">
      <view class="sa-btn" bindtap="onCall"><text>📞 拨号</text></view>
      <view class="sa-btn" bindtap="onNavigate"><text>📍 导航</text></view>
    </view>
  </view>

  <!-- Products -->
  <view class="section">
    <view class="section-title">热门产品</view>
    <view class="product-grid">
      <view class="product-card" wx:for="{{products}}" wx:key="_id" bindtap="onProduct" data-id="{{item._id}}">
        <image class="pc-img" src="{{item.image||'/images/product-80g.jpg'}}" mode="aspectFill"></image>
        <text class="pc-name">{{item.name}}</text>
        <view class="pc-price">
          <text class="pc-now">¥{{item.price}}</text>
          <text class="pc-old" wx:if="{{item.marketPrice}}">¥{{item.marketPrice}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Info -->
  <view class="section">
    <view class="section-title">门店信息</view>
    <view class="info-card">
      <view class="info-row"><text class="ir-label">营业时间</text><text class="ir-val">{{store.hours||'09:00-21:00'}}</text></view>
      <view class="info-row"><text class="ir-label">地址</text><text class="ir-val">{{store.address||'暂无'}}</text></view>
      <view class="info-row"><text class="ir-label">电话</text><text class="ir-val">{{store.phone||'暂无'}}</text></view>
    </view>
  </view>

  <!-- Owner Entry -->
  <view class="owner-entry" wx:if="{{isOwner}}" bindtap="onGoAdmin">
    <text>🔧 门店管理</text>
  </view>
</view>
<view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>
