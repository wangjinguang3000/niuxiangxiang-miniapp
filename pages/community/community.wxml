<view class="page-community">
  <view class="com-hero">
    <view class="com-coin-badge"><text class="com-coin-num">{{coins}}</text><text class="com-coin-label">金币余额</text></view>
    <view class="com-stats"><view class="com-stat"><text class="com-stat-val">{{userTier}}</text><text class="com-stat-label">会员等级</text></view></view>
  </view>
  <view class="card">
    <view class="card-title">连续签到领金币</view>
    <view class="checkin-row">
      <block wx:for="{{checkinDays}}" wx:key="index">
        <view class="checkin-day {{item.done?'done':''}} {{item.today?'today':''}}"><text class="cd-num">+{{item.reward}}</text><text class="cd-label">第{{index+1}}天</text></view>
      </block>
    </view>
    <button class="btn-checkin" bindtap="onCheckin" disabled="{{checkedToday}}">{{checkedToday?'今日已签到':'点击签到领金币'}}</button>
  </view>
  <view class="card">
    <view class="card-title">金币兑换商城</view>
    <block wx:for="{{exchanges}}" wx:key="index">
      <view class="ex-item" bindtap="onExchange" data-id="{{index}}"><text class="ex-emoji">{{item.emoji}}</text><view class="ex-info"><text class="ex-name">{{item.name}}</text><text class="ex-desc">{{item.desc}}</text></view><text class="ex-cost">{{item.cost}}金币</text></view>
    </block>
  </view>
  <view wx:if="{{ugcEnabled}}" class="card">
    <view class="card-title">宠友动态</view>
    <view class="post-input-box">
      <textarea placeholder="分享你的宠物故事..." bindinput="onTextInput" value="{{postText}}" maxlength="500" style="border:1rpx solid #ddd;border-radius:10rpx;padding:12rpx;height:120rpx;font-size:28rpx"/>
      <view wx:if="{{postImages.length>0}}" style="display:flex;flex-wrap:wrap;gap:8rpx;margin:8rpx 0">
        <block wx:for="{{postImages}}" wx:key="index"><view style="position:relative;width:120rpx;height:120rpx"><image src="{{item}}" mode="aspectFill" style="width:100%;height:100%;border-radius:8rpx"/><view bindtap="onRemoveImage" data-idx="{{index}}" style="position:absolute;top:-10rpx;right:-10rpx;background:#ff4444;color:#fff;width:36rpx;height:36rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24rpx">x</view></view></block>
      </view>
      <view style="display:flex;gap:16rpx">
        <button bindtap="onChooseImage" disabled="{{uploading}}" style="flex:1;background:#eee;color:#333;font-size:24rpx;padding:8rpx">{{uploading?'上传中...':'添加图片'}}</button>
        <button bindtap="onChooseVideo" style="flex:1;background:#eee;color:#333;font-size:24rpx;padding:8rpx">拍视频</button>
        <button bindtap="onCreatePost" disabled="{{!postText||uploading}}" style="flex:1;background:#8B5E3C;color:#fff;font-size:24rpx;padding:8rpx">发布</button>
      </view>
    </view>
    <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
    <block wx:for="{{posts}}" wx:key="_id">
      <view class="post-item" style="border-top:1rpx solid #f0f0f0;padding:16rpx 0">
        <view style="display:flex;justify-content:space-between;margin-bottom:8rpx"><text style="font-weight:bold;color:#333;font-size:28rpx">{{item.authorName||'宠友'}}</text><text style="font-size:22rpx;color:#999">{{item.createdAt}}</text></view>
        <view><text style="font-size:28rpx;color:#444;line-height:1.6">{{item.text}}</text></view>
        <view wx:if="{{item.images&&item.images.length>0}}" style="display:flex;flex-wrap:wrap;gap:6rpx;margin:10rpx 0">
          <block wx:for="{{item.images}}" wx:key="index"><image src="{{item}}" mode="aspectFill" style="width:180rpx;height:180rpx;border-radius:8rpx"/></block>
        </view>
        <view style="display:flex;gap:30rpx;margin-top:12rpx;align-items:center">
          <view bindtap="onLikePost" data-id="{{item._id}}" style="display:flex;align-items:center;gap:6rpx"><text style="font-size:32rpx">{{item.isLiked?'❤️':'🤍'}}</text><text style="font-size:24rpx;color:#999">{{item.likes||0}}</text></view>
          <view bindtap="onCommentFocus" data-id="{{item._id}}" style="display:flex;align-items:center;gap:6rpx"><text style="font-size:28rpx">💬</text><text style="font-size:24rpx;color:#999">{{item.comments||0}}</text></view>
        </view>
        <view wx:if="{{item.commentList&&item.commentList.length>0}}" style="background:#f8f8f8;border-radius:8rpx;padding:12rpx;margin-top:10rpx">
          <block wx:for="{{item.commentList}}" wx:key="id"><text style="font-size:24rpx;color:#555;display:block;margin:4rpx 0"><text style="color:#8B5E3C">{{item.authorName}}:</text> {{item.text}}</text></block>
        </view>
        <view wx:if="{{commentPostId===item._id}}" style="display:flex;gap:8rpx;margin-top:8rpx">
          <input placeholder="写评论..." bindinput="onCommentInput" value="{{commentText}}" style="flex:1;border:1rpx solid #ddd;border-radius:6rpx;padding:8rpx;font-size:24rpx"/>
          <button bindtap="onAddComment" style="background:#8B5E3C;color:#fff;font-size:22rpx;padding:8rpx 16rpx">发送</button>
        </view>
      </view>
    </block>
    <view wx:if="{{!loading&&posts.length===0}}" class="empty-tip">暂无动态，快来发布第一条！</view>
  </view>
</view>