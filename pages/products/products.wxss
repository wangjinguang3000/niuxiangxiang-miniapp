.page-products{background:#F5F0E8;padding-bottom:20px}
.hero{background:linear-gradient(135deg,#8B5E3C,#5C3A1E);color:#fff;padding:30px 16px;text-align:center}
.hero-title{font-size:20px;font-weight:700;display:block}
.hero-sub{font-size:12px;opacity:.85;display:block;margin-top:4px}
.banner-bar{background:linear-gradient(135deg,#FF6B35,#F7931E);color:#fff;padding:14px 16px;margin:10px 12px;border-radius:10px;text-align:center;font-size:13px}
.search-row{padding:10px 12px}
.search-input{width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:20px;font-size:13px;background:#fff}
.cat-scroll{white-space:nowrap;padding:0 12px 10px;display:flex;gap:6px}
.cat-tag{display:inline-block;padding:6px 14px;border-radius:16px;font-size:11px;background:#fff;border:1px solid #ddd;margin-right:6px}
.cat-tag.active{background:#8B5E3C;color:#fff;border-color:#8B5E3C}
.section-title{padding:14px 16px 8px;font-size:15px;font-weight:700}
.product-list{padding:0 12px}
.product-card{display:flex;background:#fff;border-radius:10px;margin-bottom:10px;overflow:hidden}
.product-img-wrap{width:100px;height:100px;display:flex;align-items:center;justify-content:center}
.product-emoji{font-size:36px}
.product-info{flex:1;padding:10px;display:flex;flex-direction:column;justify-content:space-between}
.product-name{font-size:13px;font-weight:700}
.product-desc{font-size:11px;color:#999}
.product-bottom{display:flex;justify-content:space-between;align-items:center}
.price{color:#C8963E;font-weight:800;font-size:15px}
.price-original{color:#999;text-decoration:line-through;font-size:11px;margin-left:4px}
.tag{font-size:10px;padding:2px 6px;border-radius:4px;color:#fff}
.tag-hot{background:#FF4757}
.tag-new{background:#5C8A45}
.tag-event{background:#C8963E}

.product-img { width: 100%; height: 100%; }
