.page-upload{background:#F5F0E8;min-height:100vh;padding-bottom:30px}
.up-hero{text-align:center;padding:40px 20px 20px}
.up-emoji{font-size:60px;display:block;margin-bottom:15px}
.up-title{font-size:22px;font-weight:bold;color:#8B5E3C;display:block;margin-bottom:6px}
.up-desc{font-size:14px;color:#999;display:block}
.up-card{background:#fff;border-radius:12px;padding:20px;margin:15px;box-shadow:0 2px 6px rgba(0,0,0,0.06)}
.up-card-title{font-size:17px;font-weight:bold;color:#333;margin-bottom:12px;display:block}
.up-pkg{padding:12px 0;border-bottom:1px solid #f5f5f5}
.up-pkg:last-child{border-bottom:none}
.up-pkg-name{font-size:15px;font-weight:bold;color:#333;display:block}
.up-pkg-price{font-size:18px;font-weight:bold;color:#E74C3C;margin:4px 0;display:block}
.up-pkg-desc{font-size:12px;color:#999;display:block}
.up-schedule{font-size:13px;color:#666;display:block;padding:6px 0}
.up-btn{background:linear-gradient(135deg,#8B5E3C,#C8963E);color:#fff;border-radius:25px;margin:20px 15px;font-size:16px;font-weight:bold}
