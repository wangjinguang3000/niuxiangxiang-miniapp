.page { background:#F5F0E8; min-height:100vh; padding:24rpx; }

.contest-hint { background:#FFF9E6; border-radius:12rpx; padding:16rpx 24rpx; margin-bottom:20rpx; }
.contest-hint text { font-size:24rpx; color:#C8963E; }

/* 视频区域 */
.video-area { width:100%; height:500rpx; background:#1a1a2e; border-radius:16rpx; overflow:hidden; margin-bottom:24rpx; }
.preview-video { width:100%; height:100%; }
.video-placeholder { width:100%; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; }
.vp-emoji { font-size:80rpx; }
.vp-text { color:#fff; font-size:28rpx; margin-top:16rpx; }
.vp-hint { color:rgba(255,255,255,.4); font-size:22rpx; margin-top:8rpx; }

/* 表单 */
.form-group { background:#fff; border-radius:16rpx; padding:24rpx; margin-bottom:20rpx; }
.form-label { font-size:28rpx; font-weight:700; color:#333; display:block; margin-bottom:12rpx; }
.required { color:#FF6B35; }
.form-input { background:#F5F0E8; border-radius:12rpx; padding:16rpx 20rpx; font-size:26rpx; color:#333; width:100%; box-sizing:border-box; }
.form-count { font-size:22rpx; color:#999; text-align:right; margin-top:8rpx; display:block; }

.tag-input-row { display:flex; gap:12rpx; }
.tag-input { flex:1; }
.tag-add-btn { background:#8B5E3C; color:#fff; font-size:24rpx; padding:0 20rpx; border-radius:12rpx; display:flex; align-items:center; white-space:nowrap; }

.tag-list { display:flex; flex-wrap:wrap; gap:12rpx; margin-top:16rpx; }
.tag-item { background:#F5F0E8; border:1rpx solid #ddd; border-radius:20rpx; padding:8rpx 16rpx; font-size:24rpx; display:flex; align-items:center; gap:8rpx; }
.tag-remove { color:#999; font-size:20rpx; }

.tag-suggestions { margin-top:16rpx; }
.suggest-label { font-size:22rpx; color:#999; }
.suggest-tag { display:inline-block; background:#FFF9E6; color:#C8963E; font-size:22rpx; padding:6rpx 14rpx; border-radius:16rpx; margin:6rpx 8rpx; }

.video-info-row { display:flex; gap:30rpx; }
.video-info-row text { font-size:24rpx; color:#666; }

.reward-hint { text-align:center; padding:16rpx; margin-bottom:20rpx; }
.reward-hint text { font-size:24rpx; color:#666; }
.gold { color:#C8963E; font-weight:700; }

.btn-row { display:flex; gap:20rpx; margin-top:20rpx; }
.btn { flex:1; text-align:center; padding:24rpx; border-radius:16rpx; font-size:30rpx; font-weight:700; }
.btn-cancel { background:#fff; color:#999; border:1rpx solid #ddd; }
.btn-submit { background:linear-gradient(135deg,#FF6B35,#F7931E); color:#fff; }
.btn-submit.disabled { opacity:.5; }
