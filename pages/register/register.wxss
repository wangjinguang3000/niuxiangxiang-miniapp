.page { padding-bottom: 40rpx; }
.form-group { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 26rpx; font-weight: 600; margin-bottom: 8rpx; color: #3D3226; }
.form-input, .form-textarea { width: 100%; padding: 20rpx; border: 2rpx solid #E8E0D5; border-radius: 12rpx; font-size: 28rpx; background: #FAF7F2; box-sizing: border-box; }
.form-textarea { height: 150rpx; }
.form-picker { width: 100%; padding: 20rpx; border: 2rpx solid #E8E0D5; border-radius: 12rpx; font-size: 28rpx; background: #FAF7F2; color: #3D3226; }